# E2E Test Configuration
#
# Base URL for the UI under test (Vite dev server)
BASE_URL=http://localhost:5173

# API URL for health checks
API_URL=http://localhost:8000

# Set to "true" to use dev auth mode (no Keycloak required)
# When false/unset, tests authenticate via Keycloak on :8080
E2E_DEV_AUTH=false

# Keycloak URL (only needed when E2E_DEV_AUTH is not "true")
KEYCLOAK_URL=http://localhost:8080
