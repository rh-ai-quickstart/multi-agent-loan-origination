# Mortgage AI -- environment configuration
# Copy to .env and adjust values for your local setup.

# -- Company display name --
# Used in UI header/footer, agent prompts, and API title.
# COMPANY_NAME=Acme FinTech Company
# AGENT_NAME=

# -- Database (Postgres container) --
POSTGRES_DB=mortgage-ai
POSTGRES_USER=user
POSTGRES_PASSWORD=password

# -- Database (application connection) --
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5433/mortgage-ai

COMPLIANCE_DATABASE_URL=postgresql+asyncpg://user:password@localhost:5433/mortgage-ai

# -- API --
DEBUG=false
ALLOWED_HOSTS=["http://localhost:3000"]

# -- Auth / Keycloak --
# Set to true to bypass JWT validation (local dev without Keycloak)
AUTH_DISABLED=true
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=mortgage-ai

# -- Safety / Shields --
# Set SAFETY_MODEL to enable Llama Guard input/output filtering.
# When not set, shields are disabled (agents work normally without filtering).
# SAFETY_ENDPOINT and SAFETY_API_KEY default to LLM_BASE_URL and LLM_API_KEY,
# so you only need them if Llama Guard runs on a different endpoint.
#SAFETY_MODEL=llama-guard-3-8b
#SAFETY_ENDPOINT=http://localhost:1234/v1
#SAFETY_API_KEY=not-needed

# -- LLM --
# API key for the OpenAI-compatible endpoint (set to real key for OpenAI)
LLM_API_KEY=not-needed
# Base URL for the LLM endpoint (local vLLM, LlamaStack, or OpenAI)
LLM_BASE_URL=https://api.openai.com/v1
# Model for simple queries (fast_small tier)
LLM_MODEL_FAST=gpt-4o-mini
# Model for complex reasoning + tool use (capable_large tier)
LLM_MODEL_CAPABLE=gpt-4o-mini

# -- MLFlow (Observability) --
# MLFlow tracking server URI. When set, tracing is active.
# Leave blank to disable tracing.
# MLFLOW_TRACKING_URI=http://localhost:5000
# MLFlow experiment name for grouping traces.
# MLFLOW_EXPERIMENT_NAME=mortgage-ai

# -- UI --
VITE_API_BASE_URL=http://localhost:8000
VITE_ENVIRONMENT=development
